    {
      "name": "add item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "// Parse response JSON\r",
              "let response = pm.response.json();\r",
              "\r",
              "// Save values as a variable\r",
              "pm.environment.set(\"user_Id\", response.data.id);\r",
              "pm.environment.set(\"project_id\", response.data.project_id);\r",
              "\r",
              "//get request data\r",
              "\r",
              "let requestData = pm.request.body.raw;\r",
              "let requestJson = JSON.parse(requestData);\r",
              "\r",
              "//get response data\r",
              "\r",
              "\r",
              "let responseJson = pm.response.json();\r",
              "\r",
              "// Extract response data\r",
              "let responseData = responseJson.data.data;\r",
              "\r",
              "// Assertions\r",
              "\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "}); \r",
              "\r",
              "pm.test(\"Name matches\", function () {\r",
              "    pm.expect(responseData.name).to.eql(requestJson.data.name);\r",
              "});\r",
              "\r",
              "pm.test(\"Price matches\", function () {\r",
              "    pm.expect(responseData.price).to.eql(requestJson.data.price);\r",
              "});\r",
              "\r",
              "pm.test(\"Category matches\", function () {\r",
              "    pm.expect(responseData.category).to.eql(requestJson.data.category);\r",
              "});\r",
              "\r",
              "pm.test(\"Stock matches\", function () {\r",
              "    pm.expect(responseData.in_stock).to.eql(requestJson.data.in_stock);\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
